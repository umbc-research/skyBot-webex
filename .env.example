# SkyBot WebEx Configuration
# Copy this file to .env and fill in your values

# WebEx Bot Token (from developer.webex.com)
WEBEX_BOT_TOKEN=your_bot_token_here

# The "Observing Nights" Space ID (create this space first, then get its ID)
WEBEX_OBSERVING_SPACE_ID=your_space_id_here

# Webhook URL (your public HTTPS endpoint)
WEBHOOK_URL=https://your-server.com/webhook

# Authorized shifter emails (comma-separated)
AUTHORIZED_SHIFTERS=shifter1@umbc.edu,shifter2@umbc.edu

# Server configuration
FLASK_PORT=8080
