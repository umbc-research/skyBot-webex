# SkyBot WebEx Configuration
# Copy this file to .env and fill in the values

# WebEx Bot Token (from developer.webex.com)
WEBEX_BOT_TOKEN=your_bot_token_here

# "Observing Sessions" space - daily check announcements post here
WEBEX_OBSERVING_SESSIONS_SPACE_ID=your_space_id_here

# "Shift Trading" space - shift rosters and trading discussions
WEBEX_SHIFT_TRADING_SPACE_ID=your_space_id_here

# Webhook URL (your public HTTPS endpoint - use ngrok for testing)
WEBHOOK_URL=https://your-ngrok-url.ngrok-free.dev/webhook

# Authorized shifter emails (comma-separated) - can trade shifts on behalf of others
AUTHORIZED_SHIFTERS=email1@umbc.edu,email2@umbc.edu

# Schedule coordinator email - mentioned on session uncancel
SCHEDULE_COORDINATOR_EMAIL=coordinator@umbc.edu

# Server port
FLASK_PORT=8080
